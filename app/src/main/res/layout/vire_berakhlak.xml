<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@drawable/backgoundovalputih"
    android:layout_margin="10dp">


        <LinearLayout
            android:paddingTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <RelativeLayout
            android:id="@+id/titleKehadiran"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingEnd="20dp"
            android:paddingStart="20dp"
            >

            <TextView
                android:layout_centerInParent="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/survei_core_value"
                android:textAlignment="center"
                android:textSize="18sp"
                android:textColor="@color/text_hitam"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:id="@+id/titleBerakhlak"
                />

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                app:srcCompat="@drawable/one_close"
                android:id="@+id/ivCloseBerakhlak"
                />
        </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp"
                android:orientation="vertical"
                android:paddingTop="10dp"
                >

                <TextView
                    android:textAlignment="inherit"
                    android:id="@+id/tvPeritahPilih"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/silahkan_pilih_core_values_asn_berakhlak_yang_anda_kerjakan_hari_ini"
                    android:textColor="@color/text_hitam"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>



                <LinearLayout
                    android:layout_below="@+id/tvPeritahPilih"
                    android:id="@+id/listBerakhlak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    >

                    <LinearLayout
                    android:id="@+id/llListBerakhlak1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:id="@+id/ivListBerakhlak1"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle_non"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/ivCheckBer1"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Ber"
                        android:textStyle="bold"
                        android:textColor="@color/merah"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="orientasi Pelayanan"
                        android:textStyle="bold"
                        android:textColor="@color/text_hitam"
                        />
                </LinearLayout>

                    <LinearLayout
                    android:id="@+id/llListBerakhlak2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">


                    <ImageView
                        android:id="@+id/ivListBerakhlak2"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle_non"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/ivCheckBer2"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="A"
                        android:textStyle="bold"
                        android:textColor="@color/merah"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="kuntabel"
                        android:textStyle="bold"
                        android:textColor="@color/text_hitam"
                        />
                </LinearLayout>

                    <LinearLayout
                    android:id="@+id/llListBerakhlak3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">


                    <ImageView
                        android:id="@+id/ivListBerakhlak3"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle_non"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/ivCheckBer3"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="K"
                        android:textStyle="bold"
                        android:textColor="@color/merah"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="ompeten"
                        android:textStyle="bold"
                        android:textColor="@color/text_hitam"
                        />
                </LinearLayout>

                    <LinearLayout
                    android:id="@+id/llListBerakhlak4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">


                    <ImageView
                        android:id="@+id/ivListBerakhlak4"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle_non"
                        android:layout_marginEnd="10dp"/>
                    <ImageView
                        android:id="@+id/ivCheckBer4"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="H"
                        android:textStyle="bold"
                        android:textColor="@color/merah"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="armonis"
                        android:textStyle="bold"
                        android:textColor="@color/text_hitam"
                        />
                </LinearLayout>

                    <LinearLayout
                    android:id="@+id/llListBerakhlak5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">


                    <ImageView
                        android:id="@+id/ivListBerakhlak5"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle_non"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/ivCheckBer5"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="L"
                        android:textStyle="bold"
                        android:textColor="@color/merah"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="oyal"
                        android:textStyle="bold"
                        android:textColor="@color/text_hitam"
                        />
                </LinearLayout>

                  <LinearLayout
                    android:id="@+id/llListBerakhlak6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">


                    <ImageView
                        android:id="@+id/ivListBerakhlak6"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle_non"
                        android:layout_marginEnd="10dp"/>
                    <ImageView
                        android:id="@+id/ivCheckBer6"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="A"
                        android:textStyle="bold"
                        android:textColor="@color/merah"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="daptif"
                        android:textStyle="bold"
                        android:textColor="@color/text_hitam"
                        />
                </LinearLayout>


                    <LinearLayout
                    android:id="@+id/llListBerakhlak7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">


                    <ImageView
                        android:id="@+id/ivListBerakhlak7"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle_non"
                        android:layout_marginEnd="10dp"/>

                    <ImageView
                        android:id="@+id/ivCheckBer7"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/one_rectangle"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="K"
                        android:textStyle="bold"
                        android:textColor="@color/merah"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="olaboratif"
                        android:textStyle="bold"
                        android:textColor="@color/text_hitam"
                        />
                </LinearLayout>
            </LinearLayout>

                <TextView
                    android:layout_centerHorizontal="true"
                    android:layout_below="@+id/listBerakhlak"
                    android:id="@+id/tvKirimSurveiBerakhlak"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/backgroundnavbar"
                    android:padding="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/kirim"
                    android:textSize="18sp"
                    android:layout_marginEnd="5dp"
                    android:textStyle="bold"
                    android:textColor="@color/text_putih"/>

        </RelativeLayout>

        </LinearLayout>
</LinearLayout>